# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_DSN=postgres://jobcrawler:secret@localhost:5432/jobcrawler?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=jobcrawler
# -1 = RequireAll (all replicas must ack), 1 = RequireOne, 0 = NoResponse
KAFKA_REQUIRED_ACKS=-1

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Comma-separated list of node addresses
ES_ADDRESSES=http://localhost:9200
ES_INDEX_NAME=jobs

# ── Crawler ───────────────────────────────────────────────────────────────────
# Requests per second per source (0.5 = 1 request every 2 seconds)
CRAWLER_RATE_LIMIT_RPS=0.5
CRAWLER_MAX_RETRIES=3
# Optional: override default user agents (comma-separated)
CRAWLER_USER_AGENTS=