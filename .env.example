# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_DSN=postgres://jobcrawler:secret@localhost:5432/jobcrawler?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=jobcrawler
# -1 = RequireAll (all replicas must ack), 1 = RequireOne, 0 = NoResponse
KAFKA_REQUIRED_ACKS=-1

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Comma-separated list of node addresses
ES_ADDRESSES=http://localhost:9200
ES_INDEX_NAME=jobs

# ── Crawler ───────────────────────────────────────────────────────────────────
# Requests per second per source (0.5 = 1 request every 2 seconds)
CRAWLER_RATE_LIMIT_RPS=0.5
CRAWLER_MAX_RETRIES=3
# Max detail-URLs one listing page may enqueue (guards against runaway selectors).
# Raise to surface more jobs per listing page; 0/unset falls back to 50.
CRAWLER_MAX_LISTING_FANOUT=50
# Optional: override default user agents (comma-separated)
CRAWLER_USER_AGENTS=

# ── Processor limits (storage growth control) ─────────────────────────────────
# Hard cap on total stored jobs. 0 = unlimited. When reached the processor pauses
# inserts (self-healing — resumes once cleanup drops the count below the cap).
MAX_TOTAL_JOBS=50000
# Retention cleanup cron (deletes jobs older than CLEANUP_RETENTION_DAYS).
CLEANUP_ENABLED=true
CLEANUP_SCHEDULE=0 3 * * *
CLEANUP_RETENTION_DAYS=30

# ── ngrok (public ingress for the API + frontend) ─────────────────────────────
# Auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Server deployment (docker-compose.yml, --profile prod) ────────────────────
# Postgres password used by the compose stack (override the dev default).
POSTGRES_PASSWORD=change-me

# The compose file's profile knobs already DEFAULT to production-safe values
# (info logs, 6h Kafka retention, auto-restart, GHCR :latest), so a server only
# needs the lines above. Override any of these only if you want non-defaults:
#   APP_ENV=production
#   LOG_LEVEL=info                 # debug logs can grow fast — keep at info on a server
#   RESTART_POLICY=unless-stopped
#   KAFKA_LOG_RETENTION_HOURS=6    # transient queue; raise only if you have disk
#   IMAGE_TAG=latest               # GHCR tag Watchtower tracks
#   ES_ADDRESSES=                  # empty on the server (no Elasticsearch; Postgres-backed)
# NOTE: leave ES_ADDRESSES empty (or unset) for server deploys — the dev value
# above (line "ES_ADDRESSES=...") points at a host that doesn't exist there.